# Public local-install settings. Blank path values use the packaged defaults below.
# Data defaults to %LOCALAPPDATA%\RFQTranslationTool\Data and is retained when the app is removed.
RFQ_PROJECT_DATA_ROOT=

# The installer normally sets the package root. Component paths default below this root.
RFQ_INSTALL_ROOT=
RFQ_RUNTIME_PYTHON=
RFQ_J_PIPELINE_PATH=
RFQ_C_PARSER_PATH=
RFQ_B_TRANSLATOR_PATH=
RFQ_D3_RUNNER_PATH=
RFQ_F_RUNNER_PATH=
# Required only for complete processing. Translation-only mode does not use this template.
RFQ_PARAMETER_CARD_TEMPLATE=

# Local-only and single-worker defaults. Do not expose the service to the public internet.
RFQ_HOST=127.0.0.1
RFQ_ENABLE_HOST_FOLDER_OPEN=0
RFQ_ENABLE_SERVER_PATH_IMPORT=0
RFQ_UVICORN_WORKERS=1

# Upload limits: 1000 files, 2 GiB per file, 20 GiB per request.
RFQ_MAX_UPLOAD_FILE_COUNT=1000
RFQ_MAX_SINGLE_FILE_BYTES=2147483648
RFQ_MAX_TOTAL_UPLOAD_BYTES=21474836480
RFQ_MIN_FREE_DISK_BYTES=5368709120
RFQ_UPLOAD_CHUNK_BYTES=1048576

# Warn only; A does not terminate a slow J process automatically.
RFQ_NO_PROGRESS_WARNING_SECONDS=1800
RFQ_APP_VERSION=A15
RFQ_APP_COMMIT=
