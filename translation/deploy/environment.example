# 仅作变量名和填写口径示例。所有值都是占位符，不可直接用于生产。
# 不要把填写后的文件提交到 Git，也不要把 API Key 写入命令历史、日志或 Manifest。

VECTOR_ENGINE_API_KEY=<由部署主机密钥管理填写>
VECTOR_ENGINE_BASE_URL=<经公司批准的OpenAI兼容服务地址>
VECTOR_ENGINE_MODEL=<主翻译模型名称>
B_PDF_TRANSLATION_REPAIR_MODEL=<修复模型名称>

B_PDF_TRANSLATION_SERVICE=<openaicompatbatch或openaicompatible或siliconflowfree>
B_PDF_TRANSLATION_PROFILE=<quality或balanced或fast>
B_PDF_TRANSLATION_QPS=<正整数>
B_PDF_TRANSLATION_WORKERS=<正整数>
B_PDF_TRANSLATION_DISABLE_THINKING=<0或1>
B_PDF_TRANSLATION_FORCE_SIMPLE_PATH=<0或1>

B_PDF_TRANSLATION_BATCH_SIZE=<正整数>
B_PDF_TRANSLATION_BATCH_MAX_CHARS=<正整数>
B_PDF_TRANSLATION_BATCH_FLUSH_MS=<正整数>
B_PDF_TRANSLATION_BATCH_TIMEOUT=<正整数秒>
B_PDF_TRANSLATION_BATCH_RETRIES=<正整数>
B_PDF_TRANSLATION_BATCH_REQUEST_WORKERS=<正整数>

B_PDF_TRANSLATION_BABELDOC_BATCH_TOKEN_LIMIT=<正整数>
B_PDF_TRANSLATION_BABELDOC_BATCH_COUNT_LIMIT=<正整数>
B_PDF_TRANSLATION_LLM_SHORT_TEXT_TOKEN_FLOOR=<正整数>
B_PDF_TRANSLATION_DOCLAYOUT_IMAGE_SIZE=<640至1280之间的32倍数>
B_PDF_TRANSLATION_TRANSLATE_CYRILLIC_FORMULA_TEXT=<0或1>
B_PDF_TRANSLATION_DISABLE_SAME_TEXT_FALLBACK=<0或1>

# 可选。供安装版健康信息记录构建来源；不填时 B 仍记录模块和运行时组件版本。
RFQ_BUILD_COMMIT=<发行提交哈希>

# 可选。PDF 多探测器预检阈值；通常保留默认值，修改会使 PDF 续跑签名失效。
B_PDF_PREFLIGHT_MIN_TEXT_CHARS=<1至200，默认12>
B_PDF_PREFLIGHT_MIN_TEXT_QUALITY=<0.1至1.0，默认0.55>
B_PDF_PREFLIGHT_SCAN_IMAGE_COVERAGE=<0.05至1.0，默认0.45>
B_PDF_PREFLIGHT_MIXED_IMAGE_COVERAGE=<0.05至1.0，默认0.35>
B_PDF_PREFLIGHT_MIN_RENDER_INK=<0.0至0.5，默认0.002>
B_PDF_PREFLIGHT_RENDER_DPI=<72至150，默认72>
B_PDF_PREFLIGHT_OCR_PROBE_DPI=<72至200，默认120>
B_PDF_PREFLIGHT_OCR_PROBE_MAX_PAGES=<1至5，默认3>

# 可选。PDF、Word、Excel 共用；多个本地私有术语文件在 Windows 下用英文分号分隔。
# 文件只保存在部署主机，不提交 Git；运行清单只记录不可逆签名和条目数。
B_PDF_TRANSLATION_PRIVATE_GLOSSARIES=<本地私有JSON或CSV术语文件完整路径>

# 普通用户默认无需设置以下两项。Windows 服务可把运行时根目录指向服务账号可写的受控短路径。
B_PDF_TRANSLATION_RUNTIME_DIR=<可选的运行时根目录>
B_PDF_TRANSLATION_PYTHON=<可选的python.exe完整覆盖路径>

B_OFFICE_TRANSLATION_BATCH_SIZE=<1至32>
B_OFFICE_TRANSLATION_BATCH_MAX_CHARS=<1至12000>
B_OFFICE_TRANSLATION_TIMEOUT=<1至300秒>
B_OFFICE_CONVERTER_PATH=<可选的soffice.exe完整路径>
